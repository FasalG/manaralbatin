rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public can read the website content; only signed-in admins can change it.
    match /site/content {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Parents can submit an enquiry; only admins can read them.
    match /registrations/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
